generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String              @id @default(uuid())
  clerkUserId           String              @unique
  email                 String              @unique
  name                  String?
  imageUrl              String?
  role                  UserRole            @default(UNASSIGNED)
  credits               Int                 @default(0)
  currentPlan           String              @default("free")
  creditsLastAllocatedAt DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  bookingsAsInterviewee Booking[]           @relation("IntervieweeBookings")
  bookingsAsInterviewer Booking[]           @relation("InterviewerBookings")
  transactions          CreditTransaction[]
  interviewerProfile    InterviewerProfile?
}

model InterviewerProfile {
  id             String              @id @default(uuid())
  userId         String              @unique
  bio            String?
  title          String?
  company        String?
  yearsExp       Int?
  categories     InterviewCategory[]
  creditRate     Int                 @default(1)
  creditBalance  Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  availabilities Availability[]
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts        Payout[]
}

model Availability {
  id            String             @id @default(uuid())
  interviewerId String
  startTime     DateTime
  endTime       DateTime
  status        AvailabilityStatus @default(AVAILABLE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  interviewer   InterviewerProfile @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([interviewerId, startTime])
}

model Booking {
  id             String              @id @default(uuid())
  intervieweeId  String
  interviewerId  String
  availabilityId String?
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus       @default(SCHEDULED)
  creditsCharged Int
  streamCallId   String?             @unique
  recordingUrl   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  availability   Availability?       @relation(fields: [availabilityId], references: [id])
  interviewee    User                @relation("IntervieweeBookings", fields: [intervieweeId], references: [id], onDelete: Cascade)
  interviewer    User                @relation("InterviewerBookings", fields: [interviewerId], references: [id], onDelete: Cascade)
  transactions   CreditTransaction[]
  feedback       Feedback?

  @@index([status, createdAt])
  @@index([interviewerId, status])
  @@index([intervieweeId, status])
}

model Feedback {
  id             String         @id @default(uuid())
  bookingId      String         @unique
  summary        String
  technical      String
  communication  String
  problemSolving String
  recommendation String
  strengths      String[]
  improvements   String[]
  overallRating  FeedbackRating
  sessionRating  Int?
  sessionComment String?
  createdAt      DateTime       @default(now())
  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id        String          @id @default(uuid())
  userId    String
  amount    Int
  type      TransactionType
  bookingId String?
  createdAt DateTime        @default(now())
  booking   Booking?        @relation(fields: [bookingId], references: [id])
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([bookingId])
}

model Payout {
  id            String             @id @default(uuid())
  interviewerId String
  credits       Int
  platformFee   Int
  netAmount     Int
  paymentMethod String
  paymentDetail String
  status        PayoutStatus       @default(PROCESSING)
  adminNote     String?
  processedAt   DateTime?
  processedBy   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  interviewer   InterviewerProfile @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([interviewerId, status])
}

enum UserRole {
  UNASSIGNED
  INTERVIEWEE
  INTERVIEWER
  ADMIN
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum InterviewCategory {
  BEHAVIORAL
  TECHNICAL
  CASE_STUDY
  LEADERSHIP
  SITUATIONAL
  PANEL
  GENERAL
}
enum FeedbackRating {
  POOR
  AVERAGE
  GOOD
  EXCELLENT
}

enum TransactionType {
  CREDIT_PURCHASE
  BOOKING_DEDUCTION
  BOOKING_EARNING
  ADMIN_ADJUSTMENT
  REFUND
}

enum PayoutStatus {
  PROCESSING
  PROCESSED
  REJECTED
}
